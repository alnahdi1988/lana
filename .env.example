SDE_ENV=local
SDE_DATABASE_HOST=localhost
SDE_DATABASE_PORT=5432
SDE_DATABASE_NAME=doctrine
SDE_DATABASE_USER=postgres
SDE_DATABASE_PASSWORD=postgres
SDE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/doctrine
SDE_REDIS_URL=redis://localhost:6379/0
SDE_POLYGON_API_KEY=
SDE_POLYGON_BASE_URL=https://api.polygon.io
SDE_POLYGON_TIMEOUT_SECONDS=20
SDE_POLYGON_UNIVERSE_REFRESH_LIMIT=200
SDE_POLYGON_INTRADAY_LOOKBACK_DAYS=30
SDE_POLYGON_DAILY_LOOKBACK_DAYS=90
SDE_POLYGON_NEWS_LOOKBACK_HOURS=72
SDE_POLYGON_NEWS_LIMIT=25
SDE_UNIVERSE_MIN_PRICE=5
SDE_UNIVERSE_MAX_PRICE=50
SDE_UNIVERSE_MIN_AVG_VOLUME_20D=500000
SDE_UNIVERSE_MIN_AVG_DOLLAR_VOLUME_20D=5000000
SDE_PHASE2_HISTORY_WINDOW_BARS=20
SDE_OPERATOR_STATE_DB_PATH=.doctrine/operations.db
SDE_RUN_INTERVAL_SECONDS=900
SDE_WEB_HOST=127.0.0.1
SDE_WEB_PORT=8000
SDE_HALT_STATUS_MODE=fail_open
SDE_TELEGRAM_ENABLED=false
SDE_TELEGRAM_BOT_TOKEN=
SDE_TELEGRAM_CHAT_ID=
SDE_ALERT_COOLDOWN_MINUTES=60
SDE_LOG_LEVEL=INFO
